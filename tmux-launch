#!/usr/bin/env bash
set -euo pipefail

# tmux-launch
# - Reads project entries from TMUX_PROJECT_LIST_FILE (default ~/.tmuxp-projects)
# - Each entry is either: /path/to/.tmuxp OR /path/to/project (containing .tmuxp)
# - Launch behavior: attach existing session, otherwise create from .tmuxp
# Usage:
#   tmux-launch
#   tmux-launch <project-name|project-path|session-name>
#   tmux-launch --detached <project-name|project-path|session-name>
#   tmux-launch status [project-name|project-path|session-name]

MANIFEST_NAME="${TMUX_PROJECT_MANIFEST:-.tmuxp}"
TMUX_BIN="${TMUX_BIN:-tmux}"
TMUX_PROJECT_LIST="${TMUX_PROJECT_LIST_FILE:-$HOME/.tmuxp-projects}"
TMUX_PROJECT_STATE_FILE="${TMUX_PROJECT_STATE_FILE:-${TMUX_PROJECT_LIST}.state}"
if ! command -v "$TMUX_BIN" >/dev/null; then
  echo "tmux not found" >&2
  exit 1
fi

if ! command -v jq >/dev/null; then
  echo "jq not found (required to read .tmuxp files)" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  tmux-launch
  tmux-launch <project-name|project-path|session-name>
  tmux-launch --detached <project-name|project-path|session-name>
  tmux-launch status [project-name|project-path|session-name]

Options:
  -d, --detached, --no-attach  create/reuse the session without attaching
  -h, --help                   show this help
EOF
}

run_in_pane() {
  local pane_id="$1"
  local pane_name="$2"
  local pane_cwd="$3"
  local command="$4"

  # Always start an interactive shell as the pane process.
  "$TMUX_BIN" respawn-pane -k -t "$pane_id" -c "$pane_cwd" "exec bash -i"

  if [[ -n "$command" && "$command" != "null" ]]; then
    # Queue startup command as if typed at the prompt so Ctrl+C interrupts only
    # the foreground app and returns to this shell.
    "$TMUX_BIN" send-keys -t "$pane_id" -l "$command"
    "$TMUX_BIN" send-keys -t "$pane_id" Enter
  fi
}

normalize_percent() {
  local raw="$1"
  local normalized

  # Accept values like "10" or "10%"; clamp to tmux-safe range.
  normalized="${raw//[^0-9]/}"
  if [[ -z "$normalized" ]]; then
    return 1
  fi
  if [[ ! "$normalized" =~ ^[0-9]+$ ]]; then
    return 1
  fi

  if (( normalized < 1 )); then
    return 1
  fi
  if (( normalized > 99 )); then
    normalized=99
  fi

  printf '%s\n' "$normalized"
}

normalize_split_option() {
  local raw="$1"
  local default_option="$2"

  if [[ -z "$raw" || "$raw" == "null" ]]; then
    printf '%s\n' "$default_option"
    return 0
  fi

  raw="${raw,,}"
  case "$raw" in
    "-h"|"h"|"horizontal"|"left-right")
      printf '%s\n' "-h"
      ;;
    "-v"|"v"|"vertical"|"top-bottom")
      printf '%s\n' "-v"
      ;;
    *)
      echo "Invalid split value '$raw'. Use horizontal/vertical (or h/v)." >&2
      return 1
      ;;
  esac
}

resolve_path() {
  local path="$1"
  local project_list_dir

  # Relative entries are resolved from the manifest file directory.
  case "$path" in
    "~"/*)
      printf '%s\n' "${HOME}${path#\~}"
      ;;
    /*)
      printf '%s\n' "$path"
      ;;
    *)
      project_list_dir="$(cd "$(dirname "$TMUX_PROJECT_LIST")" && pwd -P)"
      printf '%s\n' "$project_list_dir/$path"
      ;;
  esac
}

load_projects() {
  if [[ ! -f "$TMUX_PROJECT_LIST" ]]; then
    echo "Project list file not found: $TMUX_PROJECT_LIST" >&2
    echo "Add .tmuxp project paths there and run again." >&2
    return 1
  fi

  local -a manifest_entries
  local i
  mapfile -t manifest_entries < <(sed -E 's/[[:space:]]+$//; /^[[:space:]]*($|#)/d; s/^[[:space:]]+//' "$TMUX_PROJECT_LIST")
  if (( ${#manifest_entries[@]} == 0 )); then
    echo "No entries found in project list: $TMUX_PROJECT_LIST" >&2
    return 1
  fi

  declare -ga MANIFESTS=()
  mapfile -t MANIFESTS < <(
    for entry in "${manifest_entries[@]}"; do
      resolved=""
      resolved="$(resolve_path "$entry")"
      if [[ "$resolved" == *"/$MANIFEST_NAME" ]]; then
        echo "$resolved"
      elif [[ -f "$resolved/$MANIFEST_NAME" ]]; then
        echo "$resolved/$MANIFEST_NAME"
      fi
    done
  )
  if (( ${#MANIFESTS[@]} == 0 )); then
    echo "No readable '$MANIFEST_NAME' manifests in project list: $TMUX_PROJECT_LIST" >&2
    return 1
  fi

  declare -ga PROJECT_DIRS=()
  declare -ga PROJECT_NAMES=()
  declare -ga PROJECT_SESSIONS=()
  declare -ga PROJECT_STATES=()
  for i in "${!MANIFESTS[@]}"; do
    local dir
    local session_name_for_project
    dir="$(dirname "${MANIFESTS[$i]}")"
    PROJECT_DIRS[i]="$(cd "$dir" && pwd -P)"
    PROJECT_NAMES[i]="$(basename "${PROJECT_DIRS[i]}")"
    session_name_for_project="$(jq -r '.session // empty' "${MANIFESTS[$i]}" 2>/dev/null || true)"
    if [[ -z "$session_name_for_project" || "$session_name_for_project" == "null" ]]; then
      session_name_for_project="${PROJECT_NAMES[$i]}"
    fi
    PROJECT_SESSIONS[i]="$session_name_for_project"
    if "$TMUX_BIN" has-session -t "=$session_name_for_project" 2>/dev/null; then
      PROJECT_STATES[i]="open"
    else
      PROJECT_STATES[i]="new"
    fi
  done

  load_project_state
  sort_projects_by_recent_launch
}

load_project_state() {
  local manifest_path
  local timestamp

  declare -gA PROJECT_LAST_LAUNCHED=()
  if [[ ! -f "$TMUX_PROJECT_STATE_FILE" ]]; then
    return 0
  fi

  while IFS=$'\t' read -r manifest_path timestamp; do
    if [[ -n "$manifest_path" && "$timestamp" =~ ^[0-9]+$ ]]; then
      PROJECT_LAST_LAUNCHED["$manifest_path"]="$timestamp"
    fi
  done <"$TMUX_PROJECT_STATE_FILE"
}

sort_projects_by_recent_launch() {
  local tmp_file
  local i
  local timestamp
  local original_index
  local manifest_path
  local project_dir
  local project_name
  local session_name
  local project_state
  local -a sorted_manifests sorted_dirs sorted_names sorted_sessions sorted_states

  tmp_file="$(mktemp "${TMPDIR:-/tmp}/tmux-launch-order.XXXXXX")"
  for i in "${!MANIFESTS[@]}"; do
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "${PROJECT_LAST_LAUNCHED[${MANIFESTS[$i]}]:-0}" \
      "$i" \
      "${MANIFESTS[$i]}" \
      "${PROJECT_DIRS[$i]}" \
      "${PROJECT_NAMES[$i]}" \
      "${PROJECT_SESSIONS[$i]}" \
      "${PROJECT_STATES[$i]}"
  done | sort -t $'\t' -k1,1nr -k2,2n >"$tmp_file"

  while IFS=$'\t' read -r timestamp original_index manifest_path project_dir project_name session_name project_state; do
    sorted_manifests+=("$manifest_path")
    sorted_dirs+=("$project_dir")
    sorted_names+=("$project_name")
    sorted_sessions+=("$session_name")
    sorted_states+=("$project_state")
  done <"$tmp_file"
  rm -f "$tmp_file"

  MANIFESTS=("${sorted_manifests[@]}")
  PROJECT_DIRS=("${sorted_dirs[@]}")
  PROJECT_NAMES=("${sorted_names[@]}")
  PROJECT_SESSIONS=("${sorted_sessions[@]}")
  PROJECT_STATES=("${sorted_states[@]}")
}

record_project_launch() {
  local manifest_path="$1"
  local timestamp
  local state_dir
  local tmp_file
  local key

  load_project_state
  timestamp="$(date +%s)"
  PROJECT_LAST_LAUNCHED["$manifest_path"]="$timestamp"

  state_dir="$(dirname "$TMUX_PROJECT_STATE_FILE")"
  mkdir -p "$state_dir"
  tmp_file="$(mktemp "$state_dir/.tmux-launch-state.XXXXXX")"
  for key in "${!PROJECT_LAST_LAUNCHED[@]}"; do
    printf '%s\t%s\n' "$key" "${PROJECT_LAST_LAUNCHED[$key]}"
  done | sort -t $'\t' -k1,1 >"$tmp_file"
  mv "$tmp_file" "$TMUX_PROJECT_STATE_FILE"
}

resolve_project_root() {
  local manifest_path="$1"
  local project_root="$2"
  local configured_root

  configured_root="$(jq -r '.root // empty' "$manifest_path")"
  if [[ -n "$configured_root" && "$configured_root" != "null" ]]; then
    if [[ "$configured_root" == "~/"* ]]; then
      configured_root="${HOME}${configured_root#\~}"
    elif [[ "$configured_root" != /* ]]; then
      configured_root="$project_root/$configured_root"
    fi
    if [[ ! -d "$configured_root" ]]; then
      echo "Configured root does not exist for '$manifest_path': $configured_root" >&2
      return 1
    fi
    project_root="$(cd "$configured_root" && pwd -P)"
  fi

  printf '%s\n' "$project_root"
}

run_status_command() {
  local manifest_path="$1"
  local project_root="$2"
  local session_name="$3"
  local status_command

  status_command="$(jq -r '.status_command // empty' "$manifest_path")"
  if [[ -z "$status_command" || "$status_command" == "null" ]]; then
    echo "No status_command configured for '$session_name'." >&2
    return 1
  fi

  (
    cd "$project_root"
    export TMUX_LAUNCH_SESSION="$session_name"
    export TMUX_LAUNCH_ROOT="$project_root"
    export TMUX_LAUNCH_MANIFEST="$manifest_path"
    export TMUX_LAUNCH_PROJECT_LIST="$TMUX_PROJECT_LIST"
    export TMUX_LAUNCH_PROJECT_STATE_FILE="$TMUX_PROJECT_STATE_FILE"
    exec bash -lc "$status_command"
  )
}

choose_status_pane_pid() {
  local session_name="$1"
  local panes_output
  local pane_id
  local pane_pid
  local pane_command
  local pane_title
  local first_pid=""
  local bun_pid=""

  if ! panes_output="$("$TMUX_BIN" list-panes -t "=$session_name" -F '#{pane_id}|#{pane_pid}|#{pane_current_command}|#{pane_title}' 2>/dev/null)"; then
    echo "Session $session_name is not running."
    return 1
  fi

  while IFS='|' read -r pane_id pane_pid pane_command pane_title; do
    [[ -n "$pane_pid" ]] || continue
    if [[ -z "$first_pid" ]]; then
      first_pid="$pane_pid"
    fi
    if [[ "$pane_title" == "start" ]]; then
      printf '%s\n' "$pane_pid"
      return 0
    fi
    if [[ -z "$bun_pid" && "$pane_command" == "bun" ]]; then
      bun_pid="$pane_pid"
    fi
  done <<<"$panes_output"

  if [[ -n "$bun_pid" ]]; then
    printf '%s\n' "$bun_pid"
    return 0
  fi
  if [[ -n "$first_pid" ]]; then
    printf '%s\n' "$first_pid"
    return 0
  fi

  echo "Session $session_name has no panes."
  return 1
}

descendant_pids() {
  local root_pid="$1"
  local pid
  local ppid
  local idx=0
  local current_pid
  local child_pid
  local line
  local -a queue=("$root_pid")
  local -A children_by_parent=()
  local -A seen=()

  seen["$root_pid"]=1
  while IFS= read -r line; do
    line="${line#"${line%%[![:space:]]*}"}"
    [[ -n "$line" ]] || continue
    read -r pid ppid <<<"$line"
    [[ "$pid" =~ ^[0-9]+$ && "$ppid" =~ ^[0-9]+$ ]] || continue
    children_by_parent["$ppid"]+="${children_by_parent[$ppid]:+ }$pid"
  done < <(ps -eo pid=,ppid=)

  while (( idx < ${#queue[@]} )); do
    current_pid="${queue[$idx]}"
    ((idx += 1))
    for child_pid in ${children_by_parent[$current_pid]:-}; do
      if [[ -z "${seen[$child_pid]:-}" ]]; then
        seen["$child_pid"]=1
        queue+=("$child_pid")
      fi
    done
  done

  printf '%s\n' "${!seen[@]}"
}

normalize_status_url_host() {
  local host="$1"

  case "$host" in
    "*"|"0.0.0.0"|"[::]"|"::")
      printf '127.0.0.1\n'
      ;;
    \[*\])
      printf '%s\n' "${host:1:${#host}-2}"
      ;;
    *)
      printf '%s\n' "$host"
      ;;
  esac
}

run_builtin_status_vite_bun() {
  local session_name="$1"
  local root_pid
  local local_addr
  local host
  local port
  local rest
  local pid
  local line
  local -a listeners=()
  local -A session_pids=()

  if ! root_pid="$(choose_status_pane_pid "$session_name")"; then
    printf '%s\n' "$root_pid"
    return 0
  fi

  while IFS= read -r pid; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    session_pids["$pid"]=1
  done < <(descendant_pids "$root_pid")

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    read -r _ _ _ local_addr _ <<<"$line"
    host="${local_addr%:*}"
    port="${local_addr##*:}"
    [[ "$port" =~ ^[0-9]+$ ]] || continue

    rest="$line"
    while [[ "$rest" =~ pid=([0-9]+) ]]; do
      pid="${BASH_REMATCH[1]}"
      if [[ -n "${session_pids[$pid]:-}" ]]; then
        listeners+=("$(normalize_status_url_host "$host"):$port")
        break
      fi
      rest="${rest#*pid=$pid}"
    done
  done < <(ss -ltnpH 2>/dev/null)

  if (( ${#listeners[@]} == 0 )); then
    echo "No listening ports found for $session_name."
    return 0
  fi

  mapfile -t listeners < <(printf '%s\n' "${listeners[@]}" | sort -u -t : -k2,2n)
  echo "Vite: http://${listeners[0]}"
  if (( ${#listeners[@]} > 1 )); then
    local listener
    for listener in "${listeners[@]:1}"; do
      echo "Also listening: http://$listener"
    done
  fi
}

run_builtin_status_action() {
  local manifest_path="$1"
  local session_name="$2"
  local status_action

  status_action="$(jq -r '.status_action // empty' "$manifest_path")"
  if [[ -z "$status_action" || "$status_action" == "null" ]]; then
    echo "No status action configured for '$session_name'." >&2
    return 1
  fi

  case "$status_action" in
    "vite-bun")
      run_builtin_status_vite_bun "$session_name"
      ;;
    *)
      echo "Unknown status_action '$status_action' for '$session_name'." >&2
      return 1
      ;;
  esac
}

run_project_status() {
  local manifest_path="$1"
  local project_root="$2"
  local session_name="$3"
  local status_command

  status_command="$(jq -r '.status_command // empty' "$manifest_path")"
  if [[ -n "$status_command" && "$status_command" != "null" ]]; then
    run_status_command "$manifest_path" "$project_root" "$session_name"
    return $?
  fi

  run_builtin_status_action "$manifest_path" "$session_name"
}

status_all_projects() {
  local i
  local manifest_path
  local project_root
  local session_name
  local status_output
  local ran_any=0
  local line

  load_projects || return 1

  for i in "${!MANIFESTS[@]}"; do
    if [[ "${PROJECT_STATES[$i]}" != "open" ]]; then
      continue
    fi

    manifest_path="${MANIFESTS[$i]}"
    session_name="${PROJECT_SESSIONS[$i]}"
    project_root="$(resolve_project_root "$manifest_path" "${PROJECT_DIRS[$i]}")" || {
      printf '[%s] invalid root\n' "$session_name"
      continue
    }

    if ! status_output="$(run_project_status "$manifest_path" "$project_root" "$session_name" 2>&1)"; then
      printf '[%s] %s\n' "$session_name" "$status_output"
      ran_any=1
      continue
    fi

    printf '[%s]\n' "$session_name"
    while IFS= read -r line; do
      printf '  %s\n' "$line"
    done <<<"$status_output"
    ran_any=1
  done

  if (( ran_any == 0 )); then
    echo "No running sessions found."
  fi
}

setup_window() {
  local session_name="$1"
  local project_root="$2"
  local window_json="$3"
  local window_index="$4"

  local window_name
  local layout
  local split_option
  local base_pane
  local -a pane_defs
  local -a pane_ids pane_names
  local -A pane_ids_by_name
  local i

  # Window default: first window gets the session name.
  window_name="$(jq -r '.name // empty' <<<"$window_json")"
  if [[ -z "$window_name" || "$window_name" == "null" ]]; then
    if (( window_index == 0 )); then
      window_name="$session_name"
    else
      window_name="window-$((window_index + 1))"
    fi
  fi

  layout="$(jq -r '.layout // "vertical"' <<<"$window_json")"
  if [[ "$layout" == "null" || -z "$layout" ]]; then
    layout="vertical"
  fi
  layout="${layout,,}"
  case "$layout" in
    *horizontal*) split_option="-h" ;;
    *) split_option="-v" ;;
  esac

  mapfile -t pane_defs < <(jq -c '.panes // [] | .[]' <<<"$window_json")
  # Fallback if panes are omitted in .tmuxp.
  if (( ${#pane_defs[@]} == 0 )); then
    mapfile -t pane_defs < <(jq -nc '[
      {name:"start", percent:10, command:"bun run dev", cwd:"."},
      {name:"codex", percent:90, command:"codex resume", cwd:"."}
    ] | .[]')
  fi

  if (( window_index == 0 )); then
    # First window creates the session.
    base_pane=$("$TMUX_BIN" new-session -d -s "$session_name" -n "$window_name" -c "$project_root" -P -F '#{pane_id}' "bash")
  else
    base_pane=$("$TMUX_BIN" new-window -d -t "=$session_name" -n "$window_name" -c "$project_root" -P -F '#{pane_id}' "bash")
  fi

  for (( i = 0; i < ${#pane_defs[@]}; i++ )); do
    local pane_json="${pane_defs[$i]}"
    local pane_name
    local percent
    local command
    local pane_cwd
    local pane_split
    local pane_target
    local pane_id
    local target_pane
    local pane_split_args

    pane_name="$(jq -r '.name // empty' <<<"$pane_json")"
    if [[ -z "$pane_name" || "$pane_name" == "null" ]]; then
      pane_name="pane-$((i + 1))"
    fi

    percent="$(jq -r '.percent // empty' <<<"$pane_json")"
    command="$(jq -r '.command // empty' <<<"$pane_json")"
    pane_cwd="$(jq -r '.cwd // empty' <<<"$pane_json")"
    pane_split="$(jq -r '.split // empty' <<<"$pane_json")"
    pane_target="$(jq -r '.target // empty' <<<"$pane_json")"

    if [[ -z "$pane_cwd" || "$pane_cwd" == "null" ]]; then
      pane_cwd="."
    fi
    if [[ "$pane_cwd" != /* ]]; then
      pane_cwd="$project_root/$pane_cwd"
    fi
    if [[ ! -d "$pane_cwd" ]]; then
      echo "Pane cwd does not exist in '$window_name/$pane_name': $pane_cwd" >&2
      exit 1
    fi
    pane_cwd="$(cd "$pane_cwd" && pwd -P)"

    if (( i == 0 )); then
      # First pane reuses the base pane from new-session/new-window.
      pane_id="$base_pane"
    else
      local pane_percent
      local split_size
      pane_split="$(normalize_split_option "$pane_split" "$split_option")"
      pane_split_args=("$pane_split")

      # target can be omitted (previous pane), 1-based numeric index, or pane name.
      if [[ -z "$pane_target" || "$pane_target" == "null" ]]; then
        target_pane="${pane_ids[$((i - 1))]}"
      elif [[ "$pane_target" =~ ^[0-9]+$ ]]; then
        if (( pane_target >= 1 && pane_target <= ${#pane_ids[@]} )); then
          target_pane="${pane_ids[$((pane_target - 1))]}"
        else
          echo "Invalid numeric target '$pane_target' in '$window_name/$pane_name'." >&2
          exit 1
        fi
      elif [[ -n "${pane_ids_by_name[$pane_target]:-}" ]]; then
        target_pane="${pane_ids_by_name[$pane_target]}"
      else
        echo "Unknown target pane '$pane_target' in '$window_name/$pane_name'." >&2
        exit 1
      fi

      pane_percent="$(normalize_percent "$percent" || true)"
      if [[ -n "$pane_percent" ]]; then
        local dimension
        if [[ "$pane_split" == "-v" ]]; then
          dimension="$("$TMUX_BIN" display-message -p -t "$target_pane" '#{pane_height}' 2>/tmp/tmux-launch-dim.err || true)"
        else
          dimension="$("$TMUX_BIN" display-message -p -t "$target_pane" '#{pane_width}' 2>/tmp/tmux-launch-dim.err || true)"
        fi
        if [[ ! "$dimension" =~ ^[0-9]+$ ]]; then
          if [[ -s /tmp/tmux-launch-dim.err ]]; then
            cat /tmp/tmux-launch-dim.err >&2
            rm -f /tmp/tmux-launch-dim.err
          fi
          dimension=""
        fi
        rm -f /tmp/tmux-launch-dim.err
        if [[ -z "$dimension" ]]; then
          split_size=
        else
          # Use absolute split size (-l) because -p is unreliable on some tmux builds.
          split_size=$(( dimension * pane_percent / 100 ))
          if (( split_size < 1 )); then
            split_size=1
          fi
          if (( split_size >= dimension )); then
            split_size=$((dimension - 1))
          fi
          pane_split_args+=("-l" "$split_size")
        fi
      else
        pane_split_args=("${pane_split_args[0]}")
      fi

      pane_id=$("$TMUX_BIN" split-window -d "${pane_split_args[@]}" -t "$target_pane" -c "$pane_cwd" -P -F '#{pane_id}' "bash")
    fi

    "$TMUX_BIN" select-pane -t "$pane_id" -T "$pane_name"
    run_in_pane "$pane_id" "$pane_name" "$pane_cwd" "$command"
    pane_ids+=("$pane_id")
    pane_names+=("$pane_name")
    pane_ids_by_name["$pane_name"]="$pane_id"
  done

  if [[ "$layout" != "vertical" && "$layout" != "horizontal" ]]; then
    "$TMUX_BIN" select-layout -t "=$session_name:$window_name" "$layout" || true
  fi
}

select_project() {
  local query="${1:-}"

  # Returns one manifest path on stdout. Selection UI goes to stderr.
  local i
  load_projects || exit 1

  if [[ -n "$query" ]]; then
    for i in "${!PROJECT_NAMES[@]}"; do
      if [[ "${PROJECT_NAMES[$i]}" == "$query" || "${PROJECT_DIRS[$i]}" == "$query" || "${PROJECT_SESSIONS[$i]}" == "$query" ]]; then
        echo "${MANIFESTS[$i]}"
        return 0
      fi
    done

    for i in "${!PROJECT_NAMES[@]}"; do
      if [[ "${PROJECT_NAMES[$i],,}" == *"${query,,}"* || "${PROJECT_SESSIONS[$i],,}" == *"${query,,}"* ]]; then
        echo "${MANIFESTS[$i]}"
        return 0
      fi
    done

    echo "No project matched '$query'." >&2
    exit 1
  fi

  if command -v fzf >/dev/null 2>&1; then
    # fzf line format: index<TAB>[state]<TAB>session<TAB>path
    local choice
    choice="$((
      for i in "${!PROJECT_NAMES[@]}"; do
        printf '%d\t[%s]\t%s\t%s\n' "$((i + 1))" "${PROJECT_STATES[$i]}" "${PROJECT_SESSIONS[$i]}" "${PROJECT_DIRS[$i]}"
      done
    ) | fzf --prompt='Select a project: ' --height='~100%' --min-height=10 --layout=reverse --cycle --with-nth=2,3,4 --delimiter='\t')"

    if [[ -z "$choice" ]]; then
      echo "No project selected." >&2
      exit 1
    fi

    local selected_index
    selected_index="${choice%%$'\t'*}"
    if [[ ! "$selected_index" =~ ^[0-9]+$ ]] || (( selected_index < 1 || selected_index > ${#PROJECT_NAMES[@]} )); then
      echo "Invalid selection." >&2
      exit 1
    fi

    echo "${MANIFESTS[$((selected_index - 1))]}"
    return 0
  fi

  echo "Projects with $MANIFEST_NAME:" >&2
  for i in "${!PROJECT_NAMES[@]}"; do
    printf ' %2d) [%s] %s (%s)\n' "$((i + 1))" "${PROJECT_STATES[$i]}" "${PROJECT_SESSIONS[$i]}" "${PROJECT_DIRS[$i]}" >&2
  done

  while true; do
    local selection=""
    read -r -p "Select a project (number): " selection
    if [[ "$selection" =~ ^[0-9]+$ ]] && (( selection >= 1 && selection <= ${#PROJECT_NAMES[@]} )); then
      echo "${MANIFESTS[$((selection - 1))]}"
      return 0
    fi
    echo "Invalid selection." >&2
  done
}

action="launch"
query=""
DETACHED=0

while (( $# > 0 )); do
  case "$1" in
    status)
      if [[ "$action" != "launch" || -n "$query" ]]; then
        echo "Unexpected status argument position." >&2
        usage >&2
        exit 1
      fi
      action="status"
      ;;
    -d|--detached|--no-attach)
      DETACHED=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      if (( $# > 0 )); then
        if [[ -n "$query" ]]; then
          echo "Too many arguments." >&2
          usage >&2
          exit 1
        fi
        query="$1"
        shift
      fi
      if (( $# > 0 )); then
        echo "Too many arguments." >&2
        usage >&2
        exit 1
      fi
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$query" ]]; then
        echo "Too many arguments." >&2
        usage >&2
        exit 1
      fi
      query="$1"
      ;;
  esac
  shift
done

if [[ "$action" == "status" && -z "$query" ]]; then
  status_all_projects
  exit 0
fi

SESSION_NAME_FROM_MANIFESTS=$(select_project "$query")
if [[ -z "$SESSION_NAME_FROM_MANIFESTS" ]]; then
  exit 1
fi

manifest_path="$SESSION_NAME_FROM_MANIFESTS"
project_root="$(cd "$(dirname "$manifest_path")" && pwd -P)"

session_name="$(jq -r '.session // empty' "$manifest_path")"
if [[ -z "$session_name" || "$session_name" == "null" ]]; then
  session_name="$(basename "$project_root")"
fi

project_root="$(resolve_project_root "$manifest_path" "$project_root")"

if [[ "$action" == "status" ]]; then
  run_project_status "$manifest_path" "$project_root" "$session_name"
  exit 0
fi

LAUNCH_SESSION_NAME="$session_name"
SESSION_CREATED=0
cleanup_bad_session() {
  if (( SESSION_CREATED == 1 )) && "$TMUX_BIN" has-session -t "=$LAUNCH_SESSION_NAME" 2>/dev/null; then
    "$TMUX_BIN" kill-session -t "=$LAUNCH_SESSION_NAME" >/dev/null 2>&1 || true
  fi
}

if "$TMUX_BIN" has-session -t "=$session_name" 2>/dev/null; then
  # Fast path: session already exists, just switch/attach.
  record_project_launch "$manifest_path"
  if (( DETACHED == 1 )); then
    echo "Session ready: $session_name"
    echo "Project root: $project_root"
  elif [[ -n "${TMUX:-}" ]]; then
    "$TMUX_BIN" switch-client -t "=$session_name"
  else
    "$TMUX_BIN" attach -t "=$session_name"
  fi
  exit 0
fi

window_count="$(jq '.windows | length' "$manifest_path" 2>/dev/null || echo 0)"
mapfile -t windows < <(jq -c '(.windows // [])[]' "$manifest_path")
if (( window_count == 0 || ${#windows[@]} == 0 )); then
  # Fallback layout if windows are omitted in .tmuxp.
  windows=("$(
    jq -nc --arg name "$session_name" '{name:$name, layout:"vertical", panes:[{name:"start", percent:10, command:"bun run dev", cwd:"."}, {name:"codex", percent:90, command:"codex resume", cwd:"."}]}'
  )")
fi

trap 'cleanup_bad_session' ERR
SESSION_CREATED=1
for (( i = 0; i < ${#windows[@]}; i++ )); do
  setup_window "$session_name" "$project_root" "${windows[$i]}" "$i"
done
trap - ERR

record_project_launch "$manifest_path"
if (( DETACHED == 1 )); then
  echo "Session ready: $session_name"
  echo "Project root: $project_root"
elif [[ -n "${TMUX:-}" ]]; then
  "$TMUX_BIN" switch-client -t "=$session_name"
else
  "$TMUX_BIN" attach -t "=$session_name"
fi
